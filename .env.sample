# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
DJANGO_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY
# Supabase Postgres connection string (Project Settings -> Database -> URI).
# Use the pooled connection string for serverless (Vercel) deployments.
# Example: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://user:password@host:5432/dbname
DJANGO_DEBUG=False
# Comma-separated list of hosts (no spaces): example.com,api.example.com
ALLOWED_HOSTS=eventhub-lovat.vercel.app,example.onrender.com
# For quick testing only (not recommended in production)
CORS_ALLOW_ALL_ORIGINS=True
# Public site URL (no trailing slash). Used for CSRF trusted origins on Vercel.
SITE_URL=https://events-system-sable.vercel.app
CSRF_TRUSTED_ORIGINS=https://events-system-sable.vercel.app
GOOGLE_OAUTH_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
# Google Cloud Console -> Credentials -> OAuth 2.0 Client -> Authorized JavaScript origins:
#   https://events-system-sable.vercel.app
#   http://localhost:8000
# Error 400 origin_mismatch means the browser origin is missing from that list.

# M-Pesa Daraja (Lipa na M-Pesa Online / STK Push)
# Sandbox: shortcode 174379, test phone 254708374149
# Get Consumer Key/Secret from developer.safaricom.co.ke -> My Apps -> Event Hub
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=REPLACE_WITH_DARAJA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=REPLACE_WITH_DARAJA_CONSUMER_SECRET
MPESA_SHORTCODE=174379
MPESA_PASSKEY=REPLACE_WITH_SANDBOX_PASSKEY
MPESA_CALLBACK_URL=https://events-system-sable.vercel.app/api/payments/mpesa/stk-callback/
